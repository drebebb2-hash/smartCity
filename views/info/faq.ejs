<style>
  .faq-tab { color: #64748b; }
  .dark .faq-tab { color: #94a3b8; }
  .faq-tab.active { background-color: #4f46e5; color: white; }
  .dark .faq-tab.active { background-color: #4f46e5; color: white; }
  .faq-tab:not(.active):hover { background-color: #f1f5f9; color: #4f46e5; }
  .dark .faq-tab:not(.active):hover { background-color: #1f2937; color: #818cf8; }
  .faq-answer { transition: all 0.2s ease; }
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  (() => {
    // Accordion toggle
    document.querySelectorAll('.faq-trigger').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const item = trigger.closest('.faq-item');
        const answer = item.querySelector('.faq-answer');
        const chevron = trigger.querySelector('.faq-chevron');
        const isOpen = !answer.classList.contains('hidden');

        // Close all
        document.querySelectorAll('.faq-answer').forEach((a) => a.classList.add('hidden'));
        document.querySelectorAll('.faq-chevron').forEach((c) => c.style.transform = '');
        document.querySelectorAll('.faq-trigger').forEach((t) => {
          t.classList.remove('border-indigo-300', 'bg-indigo-50', 'dark:bg-indigo-950/20', 'dark:border-indigo-800');
        });

        if (!isOpen) {
          answer.classList.remove('hidden');
          chevron.style.transform = 'rotate(180deg)';
          trigger.classList.add('border-indigo-300', 'bg-indigo-50', 'dark:bg-indigo-950/20', 'dark:border-indigo-800');
        }
      });
    });

    // Tab filter
    const tabs = document.querySelectorAll('.faq-tab');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((t) => t.classList.remove('active'));
        tab.classList.add('active');
        const category = tab.dataset.tab;
        filterFAQ(category, document.getElementById('faqSearch').value.toLowerCase());
      });
    });

    // Search
    document.getElementById('faqSearch').addEventListener('input', (e) => {
      const activeTab = document.querySelector('.faq-tab.active')?.dataset.tab || 'all';
      filterFAQ(activeTab, e.target.value.toLowerCase());
    });

    function filterFAQ(category, query) {
      const items = document.querySelectorAll('.faq-item');
      let visibleCount = 0;

      items.forEach((item) => {
        const itemCategory = item.dataset.category;
        const itemQuestion = (item.dataset.question || '').toLowerCase();
        const questionText = item.querySelector('.faq-trigger p')?.textContent.toLowerCase() || '';

        const categoryMatch = category === 'all' || itemCategory === category;
        const searchMatch = !query || itemQuestion.includes(query) || questionText.includes(query);

        if (categoryMatch && searchMatch) {
          item.classList.remove('hidden');
          visibleCount++;
        } else {
          item.classList.add('hidden');
          // Close hidden items
          item.querySelector('.faq-answer')?.classList.add('hidden');
          const chevron = item.querySelector('.faq-chevron');
          if (chevron) chevron.style.transform = '';
        }
      });

      document.getElementById('noResults').classList.toggle('hidden', visibleCount > 0);
    }
  })();
</script>

