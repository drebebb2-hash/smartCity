<%- include('../partials/header', { title, extraHead }) %>

<main class="min-h-screen bg-gray-50 py-12 dark:bg-gray-900">
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-8 text-center">
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-950 dark:text-white sm:text-4xl">📅 Kalender Event Kota</h1>
      <p class="mt-3 text-base font-medium text-slate-500 dark:text-slate-400">Jadwal kegiatan dan event yang akan berlangsung di kota kita</p>
    </div>

    <div class="rounded-2xl bg-white p-6 shadow-lg dark:bg-gray-800">
      <div id="calendar"></div>
    </div>
  </section>
</main>

<div id="event-modal" class="fixed inset-0 z-50 hidden bg-black/50 p-4" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="flex min-h-full items-center justify-center">
    <div class="w-full max-w-md rounded-2xl bg-white p-6 shadow-2xl dark:bg-gray-800" data-modal-card>
      <h2 id="modal-title" class="text-2xl font-extrabold text-slate-950 dark:text-white"></h2>
      <p id="modal-date" class="mt-2 font-semibold text-indigo-600 dark:text-indigo-300"></p>
      <p id="modal-desc" class="mt-4 leading-7 text-slate-600 dark:text-slate-300"></p>
      <button id="modal-close" type="button" class="mt-6 w-full rounded-xl bg-indigo-600 px-4 py-3 text-sm font-bold text-white transition-all duration-200 hover:bg-indigo-700 active:scale-95">Tutup</button>
    </div>
  </div>
</div>

<style>
  .fc-toolbar-title { font-weight: 700; }
  .fc-button { border-radius: 8px !important; }
  .fc-event { cursor: pointer; border-radius: 6px !important; }
  body.dark .fc-theme-standard td, body.dark .fc-theme-standard th,
  html.dark .fc-theme-standard td, html.dark .fc-theme-standard th { border-color: #374151; }
  body.dark .fc-day-today, html.dark .fc-day-today { background: #1e3a5f !important; }
  body.dark .fc, html.dark .fc { color: #f9fafb; }
  html.dark .fc .fc-button { background-color: #374151; border-color: #4b5563; color: #f9fafb; }
  html.dark .fc .fc-button-primary:not(:disabled).fc-button-active,
  html.dark .fc .fc-button-primary:not(:disabled):active { background-color: #4f46e5; border-color: #4f46e5; }
</style>

<script>
  const events = [
    { title: "Car Free Day", daysOfWeek: [0], color: "#10b981", description: "Setiap hari Minggu, jalan protokol bebas kendaraan bermotor. Nikmati udara segar bersama keluarga." },
    { title: "Pasar Malam Rakyat", start: "2026-07-05", end: "2026-07-08", color: "#f59e0b", description: "Pasar malam rakyat dengan berbagai kuliner dan hiburan lokal selama 3 hari di alun-alun kota." },
    { title: "Vaksinasi Gratis Puskesmas", start: "2026-07-10", color: "#3b82f6", description: "Vaksinasi gratis untuk seluruh warga. Bawa KTP dan datang ke puskesmas terdekat." },
    { title: "Gotong Royong Kelurahan", start: "2026-07-12", color: "#8b5cf6", description: "Kegiatan gotong royong bersih-bersih lingkungan seluruh kelurahan. Wajib diikuti perwakilan tiap RT." },
    { title: "Sosialisasi Smart City", start: "2026-07-15", color: "#ef4444", description: "Sosialisasi program Smart City kepada warga. Diselenggarakan di Gedung Serbaguna Kecamatan pukul 09.00." },
    { title: "Festival Budaya Kota", start: "2026-07-20", end: "2026-07-23", color: "#f97316", description: "Festival budaya tahunan menampilkan kesenian daerah, pameran UMKM, dan pertunjukan musik selama 3 hari." },
    { title: "Rapat Warga RW 05", start: "2026-07-25", color: "#06b6d4", description: "Rapat koordinasi warga RW 05 membahas program lingkungan dan keamanan. Pukul 19.00 di balai RW." },
    { title: "Pemeriksaan Kesehatan Gratis", start: "2026-07-28", color: "#10b981", description: "Pemeriksaan kesehatan gratis meliputi tekanan darah, gula darah, dan konsultasi dokter umum." }
  ];

  const modal = document.getElementById('event-modal');
  const closeModal = () => modal.classList.add('hidden');

  const calendar = new FullCalendar.Calendar(document.getElementById('calendar'), {
    initialView: 'dayGridMonth',
    locale: 'id',
    headerToolbar: { left: 'prev,next today', center: 'title', right: 'dayGridMonth,timeGridWeek,listMonth' },
    events: events,
    eventClick: function(info) {
      document.getElementById('modal-title').textContent = info.event.title;
      document.getElementById('modal-date').textContent = info.event.start.toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
      document.getElementById('modal-desc').textContent = info.event.extendedProps.description;
      modal.classList.remove('hidden');
    }
  });
  calendar.render();

  document.getElementById('modal-close').addEventListener('click', closeModal);
  modal.addEventListener('click', (event) => {
    if (event.target === modal) closeModal();
  });
</script>

<%- include('../partials/footer') %>
