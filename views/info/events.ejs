<%- include('../partials/header', { title, extraHead }) %>

<main class="animate-fadeIn bg-slate-50 dark:bg-gray-900">
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="mb-10 max-w-3xl">
      <p class="text-sm font-bold uppercase tracking-wide text-indigo-600">Agenda Kota</p>
      <h1 class="mt-3 text-3xl font-extrabold tracking-tight text-slate-950 dark:text-white sm:text-4xl">Kalender Event Kota</h1>
      <p class="mt-3 text-base leading-7 text-slate-500 dark:text-slate-400">Jadwal kegiatan dan event yang akan berlangsung di kota kita.</p>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-md dark:border-gray-800 dark:bg-gray-900 sm:p-6">
      <div id="calendar"></div>
    </div>
  </section>
</main>

<div id="event-modal" class="fixed inset-0 z-50 hidden bg-slate-950/50 p-4 backdrop-blur-sm" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="flex min-h-full items-center justify-center">
    <div class="w-full max-w-md rounded-3xl border border-slate-200 bg-white p-6 shadow-2xl dark:border-gray-700 dark:bg-gray-900" data-modal-card>
      <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600 dark:bg-indigo-950 dark:text-indigo-300">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <h2 id="modal-title" class="text-2xl font-extrabold text-slate-950 dark:text-white"></h2>
      <p id="modal-date" class="mt-2 font-semibold text-indigo-600 dark:text-indigo-300"></p>
      <p id="modal-desc" class="mt-4 leading-7 text-slate-600 dark:text-slate-300"></p>
      <button id="modal-close" type="button" class="mt-6 w-full rounded-2xl bg-indigo-600 px-4 py-3 text-sm font-bold text-white shadow-sm transition-all duration-200 hover:bg-indigo-700 active:scale-95">Tutup</button>
    </div>
  </div>
</div>

<style>
  .fc-toolbar-title { font-weight: 700; color: #0f172a; }
  .fc-button { border-radius: 12px !important; font-weight: 700 !important; }
  .fc-event { cursor: pointer; border-radius: 8px !important; border: 0 !important; padding: 2px 4px; }
  .fc .fc-button-primary { background-color: #4f46e5; border-color: #4f46e5; }
  .fc .fc-button-primary:hover { background-color: #4338ca; border-color: #4338ca; }
  .fc .fc-daygrid-day-number, .fc .fc-col-header-cell-cushion { color: #334155; font-weight: 600; }
  body.dark .fc-theme-standard td, body.dark .fc-theme-standard th,
  html.dark .fc-theme-standard td, html.dark .fc-theme-standard th { border-color: #374151; }
  body.dark .fc-day-today, html.dark .fc-day-today { background: #1e3a5f !important; }
  body.dark .fc, html.dark .fc { color: #f9fafb; }
  html.dark .fc-toolbar-title, html.dark .fc .fc-daygrid-day-number, html.dark .fc .fc-col-header-cell-cushion { color: #f9fafb; }
  html.dark .fc .fc-button { background-color: #4f46e5; border-color: #4f46e5; color: #f9fafb; }
  html.dark .fc .fc-button-primary:not(:disabled).fc-button-active,
  html.dark .fc .fc-button-primary:not(:disabled):active { background-color: #6366f1; border-color: #6366f1; }
</style>

<script>
  const events = [
    {
      title: "🚗 Car Free Day",
      start: "2026-07-05",
      color: "#10b981",
      description: "Jalan protokol bebas kendaraan bermotor. Nikmati udara segar bersama keluarga di pusat kota."
    },
    {
      title: "🌙 Pasar Malam Rakyat",
      start: "2026-07-05",
      end: "2026-07-08",
      color: "#f59e0b",
      description: "Pasar malam rakyat dengan berbagai kuliner dan hiburan lokal selama 3 hari di alun-alun kota."
    },
    {
      title: "💉 Vaksinasi Gratis",
      start: "2026-07-10",
      color: "#3b82f6",
      description: "Vaksinasi gratis untuk seluruh warga. Bawa KTP dan datang ke puskesmas terdekat."
    },
    {
      title: "🧹 Gotong Royong",
      start: "2026-07-12",
      color: "#8b5cf6",
      description: "Gotong royong bersih-bersih lingkungan seluruh kelurahan. Wajib diikuti perwakilan tiap RT."
    },
    {
      title: "🏙️ Sosialisasi Smart City",
      start: "2026-07-15",
      color: "#ef4444",
      description: "Sosialisasi program Smart City kepada warga. Di Gedung Serbaguna Kecamatan pukul 09.00."
    },
    {
      title: "🎭 Festival Budaya Kota",
      start: "2026-07-20",
      end: "2026-07-23",
      color: "#f97316",
      description: "Festival budaya tahunan: kesenian daerah, pameran UMKM, pertunjukan musik selama 3 hari."
    },
    {
      title: "👥 Rapat Warga RW 05",
      start: "2026-07-25",
      color: "#06b6d4",
      description: "Rapat koordinasi warga RW 05 membahas program lingkungan dan keamanan. Pukul 19.00 di balai RW."
    },
    {
      title: "🏥 Cek Kesehatan Gratis",
      start: "2026-07-28",
      color: "#10b981",
      description: "Pemeriksaan tekanan darah, gula darah, dan konsultasi dokter umum gratis untuk warga."
    },
    {
      title: "📚 Pelatihan UMKM Digital",
      start: "2026-07-08",
      color: "#6366f1",
      description: "Pelatihan digitalisasi usaha untuk pelaku UMKM kota. Pendaftaran di kantor kecamatan."
    },
    {
      title: "🌳 Tanam Pohon Bersama",
      start: "2026-07-18",
      color: "#16a34a",
      description: "Program penghijauan kota, tanam pohon bersama di taman kota dan median jalan."
    }
  ];

  const modal = document.getElementById('event-modal');
  const closeModal = () => modal.classList.add('hidden');

  const calendar = new FullCalendar.Calendar(document.getElementById('calendar'), {
    initialView: 'dayGridMonth',
    locale: 'id',
    headerToolbar: { left: 'prev,next today', center: 'title', right: 'dayGridMonth,timeGridWeek,listMonth' },
    events: events,
    eventClick: function(info) {
      document.getElementById('modal-title').textContent = info.event.title;
      document.getElementById('modal-date').textContent = info.event.start.toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
      document.getElementById('modal-desc').textContent = info.event.extendedProps.description;
      modal.classList.remove('hidden');
    }
  });
  calendar.render();

  document.getElementById('modal-close').addEventListener('click', closeModal);
  modal.addEventListener('click', (event) => {
    if (event.target === modal) closeModal();
  });
</script>

<%- include('../partials/footer') %>
