<%- include('../partials/header', { title }) %>

<main class="mx-auto max-w-6xl px-4 py-10">
  <div class="grid gap-6 lg:grid-cols-[240px_1fr]">
    <%- include('partials/nav', { activeMenu: 'dashboard' }) %>

    <section>
      <div class="mb-8">
        <p class="text-sm font-semibold uppercase tracking-wide text-emerald-700">Ringkasan Sistem</p>
        <h1 class="mt-2 text-3xl font-bold text-slate-950">Dashboard Admin</h1>
        <p class="mt-2 text-slate-600">Pantau volume laporan dan status penanganan seluruh warga.</p>
      </div>

      <% if (error) { %>
        <div class="mb-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
          <%= error %>
        </div>
      <% } %>

      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
        <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
          <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg bg-slate-900 text-white">Σ</div>
          <p class="text-sm font-medium text-slate-500">Total Laporan</p>
          <p class="mt-2 text-3xl font-bold text-slate-950"><%= stats.total %></p>
        </article>

        <% ['pending', 'diproses', 'selesai', 'ditolak'].forEach((status) => { %>
          <% const meta = getStatusMeta(status); %>
          <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
            <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg border text-lg <%= meta.className %>"><%= meta.icon %></div>
            <p class="text-sm font-medium text-slate-500"><%= meta.label %></p>
            <p class="mt-2 text-3xl font-bold text-slate-950"><%= stats[status] %></p>
          </article>
        <% }) %>
      </div>

      <div class="mt-8 rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h2 class="text-lg font-semibold text-slate-950">Kelola Laporan</h2>
            <p class="mt-1 text-sm text-slate-500">Buka daftar lengkap laporan untuk filter dan pemeriksaan detail.</p>
          </div>
          <a href="/admin/reports" class="inline-flex rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-emerald-700">Lihat Semua Laporan</a>
        </div>
      </div>
    </section>
  </div>
</main>

<%- include('../partials/footer') %>
