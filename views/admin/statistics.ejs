<%- include('../partials/header', { title }) %>

<main class="mx-auto max-w-6xl px-4 py-10">
  <div class="grid gap-6 lg:grid-cols-[240px_1fr]">
    <%- include('partials/nav', { activeMenu: 'statistics' }) %>

    <section>
      <div class="mb-8">
        <p class="text-sm font-semibold uppercase tracking-wide text-emerald-700">Analitik Laporan</p>
        <h1 class="mt-2 text-3xl font-bold text-slate-950">Statistik</h1>
        <p class="mt-2 text-slate-600">Visualisasi kategori, status, tren laporan, dan kepuasan warga.</p>
      </div>

      <div id="statsError" class="mb-6 hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 shadow-sm"></div>

      <div id="statsLoading" class="mb-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <% for (let i = 0; i < 4; i += 1) { %>
          <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="h-4 w-28 animate-pulse rounded bg-slate-200"></div>
            <div class="mt-4 h-9 w-20 animate-pulse rounded bg-slate-200"></div>
          </div>
        <% } %>
      </div>

      <div class="mb-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
        <p class="text-sm font-medium text-slate-500">Rata-rata Rating Kepuasan</p>
        <div class="mt-2 flex items-end gap-2">
          <p id="averageRating" class="text-4xl font-bold text-slate-950">-</p>
          <p class="pb-1 text-sm text-slate-500">/ 5</p>
        </div>
      </div>

      <div class="grid gap-6 xl:grid-cols-2">
        <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <div class="mb-4">
            <h2 class="font-semibold text-slate-950">Laporan per Kategori</h2>
            <p class="mt-1 text-sm text-slate-500">Jumlah laporan berdasarkan kategori masalah.</p>
          </div>
          <div class="relative h-80">
            <canvas id="categoryChart"></canvas>
            <div id="categoryEmpty" class="hidden absolute inset-0 flex items-center justify-center rounded-xl border border-dashed border-slate-200 bg-slate-50 text-center">
              <p class="px-4 text-sm text-slate-500">Belum ada data kategori untuk divisualisasikan.</p>
            </div>
          </div>
        </article>

        <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <div class="mb-4">
            <h2 class="font-semibold text-slate-950">Distribusi Status</h2>
            <p class="mt-1 text-sm text-slate-500">Proporsi laporan berdasarkan status terkini.</p>
          </div>
          <div class="relative h-80">
            <canvas id="statusChart"></canvas>
            <div id="statusEmpty" class="hidden absolute inset-0 flex items-center justify-center rounded-xl border border-dashed border-slate-200 bg-slate-50 text-center">
              <p class="px-4 text-sm text-slate-500">Belum ada distribusi status yang bisa ditampilkan.</p>
            </div>
          </div>
        </article>

        <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md xl:col-span-2">
          <div class="mb-4">
            <h2 class="font-semibold text-slate-950">Tren 8 Minggu Terakhir</h2>
            <p class="mt-1 text-sm text-slate-500">Jumlah laporan baru per minggu.</p>
          </div>
          <div class="relative h-80">
            <canvas id="weeklyChart"></canvas>
            <div id="weeklyEmpty" class="hidden absolute inset-0 flex items-center justify-center rounded-xl border border-dashed border-slate-200 bg-slate-50 text-center">
              <p class="px-4 text-sm text-slate-500">Belum ada tren mingguan yang tersedia.</p>
            </div>
          </div>
        </article>
      </div>
    </section>
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const palette = {
    emerald: '#059669',
    yellow: '#ca8a04',
    blue: '#2563eb',
    green: '#16a34a',
    red: '#dc2626',
    slate: '#64748b',
    teal: '#0d9488',
    violet: '#7c3aed',
    orange: '#ea580c'
  };

  const chartColors = [
    palette.emerald,
    palette.blue,
    palette.yellow,
    palette.red,
    palette.teal,
    palette.violet,
    palette.orange,
    palette.slate
  ];

  function showError(message) {
    const errorBox = document.getElementById('statsError');
    errorBox.textContent = message;
    errorBox.classList.remove('hidden');
  }

  function setLoading(isLoading) {
    document.getElementById('statsLoading').classList.toggle('hidden', !isLoading);
  }

  function toggleChartEmpty(id, canvasId, items) {
    const hasData = Array.isArray(items) && items.some((item) => Number(item.count) > 0);
    document.getElementById(id).classList.toggle('hidden', hasData);
    document.getElementById(canvasId).classList.toggle('hidden', !hasData);
    return hasData;
  }

  function createCategoryChart(items) {
    const ctx = document.getElementById('categoryChart');

    return new Chart(ctx, {
      type: 'bar',
      data: {
        labels: items.map((item) => item.label),
        datasets: [{
          label: 'Jumlah laporan',
          data: items.map((item) => item.count),
          backgroundColor: chartColors
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { precision: 0 }
          }
        }
      }
    });
  }

  function createStatusChart(items) {
    const ctx = document.getElementById('statusChart');
    const statusColors = {
      pending: palette.yellow,
      diproses: palette.blue,
      selesai: palette.green,
      ditolak: palette.red
    };

    return new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels: items.map((item) => item.label),
        datasets: [{
          data: items.map((item) => item.count),
          backgroundColor: items.map((item) => statusColors[item.status] || palette.slate)
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { position: 'bottom' }
        }
      }
    });
  }

  function createWeeklyChart(items) {
    const ctx = document.getElementById('weeklyChart');

    return new Chart(ctx, {
      type: 'line',
      data: {
        labels: items.map((item) => item.label),
        datasets: [{
          label: 'Laporan',
          data: items.map((item) => item.count),
          borderColor: palette.emerald,
          backgroundColor: 'rgba(5, 150, 105, 0.12)',
          fill: true,
          tension: 0.35
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { precision: 0 }
          }
        }
      }
    });
  }

  async function loadStats() {
    try {
      const response = await fetch('/api/admin/stats-data');

      if (!response.ok) {
        const errorData = await response.json().catch(() => ({}));
        throw new Error(errorData.message || 'Gagal memuat statistik.');
      }

      const data = await response.json();
      document.getElementById('averageRating').textContent = data.averageRating ?? '0';

      const categories = data.reportsByCategory || [];
      const statuses = data.reportsByStatus || [];
      const weeks = data.reportsByWeek || [];

      if (toggleChartEmpty('categoryEmpty', 'categoryChart', categories)) createCategoryChart(categories);
      if (toggleChartEmpty('statusEmpty', 'statusChart', statuses)) createStatusChart(statuses);
      if (toggleChartEmpty('weeklyEmpty', 'weeklyChart', weeks)) createWeeklyChart(weeks);
    } catch (error) {
      showError(error.message);
    } finally {
      setLoading(false);
    }
  }

  setLoading(true);
  loadStats();
</script>

<%- include('../partials/footer') %>
