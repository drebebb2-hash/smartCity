<%- include('../partials/header', { title }) %>

<main class="mx-auto max-w-6xl px-4 py-10">
  <div class="grid gap-6 lg:grid-cols-[240px_1fr]">
    <%- include('partials/nav', { activeMenu: 'reports' }) %>

    <section>
      <div class="mb-8 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-emerald-700">Manajemen Laporan</p>
          <h1 class="mt-2 text-3xl font-bold text-slate-950">Semua Laporan</h1>
          <p class="mt-2 text-slate-600">Filter laporan berdasarkan status, kategori, atau judul laporan.</p>
        </div>
        <div class="flex flex-wrap gap-2">
          <a href="/admin/reports/export/pdf<%= exportQuery ? `?${exportQuery}` : '' %>" class="inline-flex items-center rounded-lg border border-red-200 bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 transition hover:bg-red-100">
            Export PDF
          </a>
          <a href="/admin/reports/export/excel<%= exportQuery ? `?${exportQuery}` : '' %>" class="inline-flex items-center rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-2 text-sm font-semibold text-emerald-700 transition hover:bg-emerald-100">
            Export Excel
          </a>
        </div>
      </div>

      <% if (error) { %>
        <div class="mb-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
          <%= error %>
        </div>
      <% } %>

      <form action="/admin/reports" method="GET" class="mb-6 rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
        <div class="grid gap-4 md:grid-cols-[1fr_1fr_1.4fr_auto] md:items-end">
          <div>
            <label for="status" class="mb-2 block text-sm font-medium text-slate-700">Status</label>
            <select id="status" name="status" class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100">
              <option value="">Semua status</option>
              <% statusList.forEach((status) => { %>
                <% const meta = getStatusMeta(status); %>
                <option value="<%= status %>" <%= filters.status === status ? 'selected' : '' %>><%= meta.label %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label for="category" class="mb-2 block text-sm font-medium text-slate-700">Kategori</label>
            <select id="category" name="category" class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100">
              <option value="">Semua kategori</option>
              <% categories.forEach((category) => { %>
                <option value="<%= category.id %>" <%= filters.category === category.id ? 'selected' : '' %>><%= category.icon ? `${category.icon} ` : '' %><%= category.name %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label for="search" class="mb-2 block text-sm font-medium text-slate-700">Cari Judul</label>
            <input id="search" name="search" type="search" value="<%= filters.search %>" placeholder="Masukkan kata kunci judul" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100">
          </div>

          <div class="flex gap-2">
            <button type="submit" class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-emerald-700">Filter</button>
            <a href="/admin/reports" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100">Reset</a>
          </div>
        </div>
      </form>

      <section class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
        <div class="hidden overflow-x-auto lg:block">
          <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Laporan</th>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Pelapor</th>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Petugas</th>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Kategori</th>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Status</th>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Tanggal</th>
                <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-slate-500">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
              <% reports.forEach((report) => { %>
                <% const meta = getStatusMeta(report.status); %>
                <tr>
                  <td class="px-4 py-4">
                    <div class="flex items-center gap-3">
                      <div class="h-14 w-20 overflow-hidden rounded-lg bg-slate-100">
                        <% if (report.photo_url) { %>
                          <img src="<%= report.photo_url %>" alt="<%= report.title %>" class="h-full w-full object-cover">
                        <% } %>
                      </div>
                      <p class="max-w-xs font-medium text-slate-950"><%= report.title %></p>
                    </div>
                  </td>
                  <td class="px-4 py-4 text-sm text-slate-600"><%= report.profiles?.full_name || 'Tidak diketahui' %></td>
                  <td class="px-4 py-4 text-sm text-slate-600"><%= report.assignedProfile?.full_name || 'Belum ditugaskan' %></td>
                  <td class="px-4 py-4 text-sm text-slate-600"><%= report.categories?.icon ? `${report.categories.icon} ` : '' %><%= report.categories?.name || '-' %></td>
                  <td class="px-4 py-4"><span class="rounded-full border px-2.5 py-1 text-xs font-semibold <%= meta.className %>"><%= meta.label %></span></td>
                  <td class="px-4 py-4 text-sm text-slate-600"><%= formatDate(report.created_at) %></td>
                  <td class="px-4 py-4 text-right"><a href="/reports/<%= report.id %>" class="text-sm font-semibold text-emerald-700 hover:text-emerald-800">Lihat Detail</a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div class="grid gap-4 p-4 lg:hidden">
          <% reports.forEach((report) => { %>
            <% const meta = getStatusMeta(report.status); %>
            <article class="rounded-lg border border-slate-200 p-4">
              <div class="mb-3 flex gap-3">
                <div class="h-20 w-24 shrink-0 overflow-hidden rounded-lg bg-slate-100">
                  <% if (report.photo_url) { %>
                    <img src="<%= report.photo_url %>" alt="<%= report.title %>" class="h-full w-full object-cover">
                  <% } %>
                </div>
                <div>
                  <h2 class="font-semibold text-slate-950"><%= report.title %></h2>
                  <p class="mt-1 text-sm text-slate-500"><%= formatDate(report.created_at) %></p>
                </div>
              </div>
              <div class="space-y-2 text-sm text-slate-600">
                <p>Pelapor: <span class="font-medium text-slate-900"><%= report.profiles?.full_name || 'Tidak diketahui' %></span></p>
                <p>Petugas: <span class="font-medium text-slate-900"><%= report.assignedProfile?.full_name || 'Belum ditugaskan' %></span></p>
                <p>Kategori: <%= report.categories?.icon ? `${report.categories.icon} ` : '' %><%= report.categories?.name || '-' %></p>
                <span class="inline-flex rounded-full border px-2.5 py-1 text-xs font-semibold <%= meta.className %>"><%= meta.label %></span>
              </div>
              <a href="/reports/<%= report.id %>" class="mt-4 inline-flex text-sm font-semibold text-emerald-700 hover:text-emerald-800">Lihat Detail</a>
            </article>
          <% }) %>
        </div>

        <% if (!reports.length) { %>
          <div class="px-6 py-12 text-center">
            <h2 class="text-lg font-semibold text-slate-950">Tidak ada laporan</h2>
            <p class="mt-2 text-sm text-slate-500">Coba ubah filter atau kata kunci pencarian.</p>
          </div>
        <% } %>
      </section>
    </section>
  </div>
</main>

<%- include('../partials/footer') %>
