      <a href="<%= item[1] %>" class="flex items-center gap-3 rounded-2xl px-3 py-3 text-sm font-semibold transition-all duration-200 active:scale-95 <%= activeMenu === item[0] ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-900/30' : 'text-gray-300 hover:bg-white/10 hover:text-white' %>">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="<%= item[3] %>" stroke-linecap="round" stroke-linejoin="round"/></svg>
