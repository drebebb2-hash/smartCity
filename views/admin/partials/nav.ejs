<aside class="overflow-hidden rounded-3xl bg-gray-900 p-4 text-white shadow-xl lg:sticky lg:top-24">
  <div class="mb-6 flex items-center gap-3 border-b border-white/10 pb-5">
    <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-indigo-600"><svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 21V9l5-4 5 4v12"/><path d="M14 21V5h6v16"/></svg></span>
