<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' && title.includes('Smart City Report') ? title : `${typeof title !== 'undefined' ? title : 'Beranda'} - Smart City Report` %></title>
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%23059669'/%3E%3Ctext x='32' y='39' text-anchor='middle' font-family='Arial,sans-serif' font-size='22' font-weight='700' fill='white'%3ESC%3C/text%3E%3C/svg%3E">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          boxShadow: {
            soft: '0 18px 45px rgba(15, 23, 42, 0.08)'
          }
        }
      }
    };
  </script>
</head>
<body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
<nav class="sticky top-0 z-[1100] border-b border-slate-200 bg-white/95 backdrop-blur">
  <div class="mx-auto max-w-6xl px-4 py-3">
    <div class="flex items-center justify-between gap-3">
      <a href="/" class="group flex min-w-0 items-center gap-2 text-lg font-semibold text-slate-950 transition hover:text-emerald-700">
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-emerald-600 text-sm font-bold text-white shadow-sm transition group-hover:scale-105 group-hover:bg-emerald-700">SC</span>
        <span class="truncate">Smart City Report</span>
      </a>

      <button id="mobileMenuButton" type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 text-slate-700 transition hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-emerald-100 lg:hidden" aria-controls="siteNavMenu" aria-expanded="false" aria-label="Buka menu navigasi">
        <span class="text-xl" aria-hidden="true">☰</span>
      </button>

      <div id="siteNavMenu" class="hidden items-center gap-2 lg:flex">
        <% if (currentUser) { %>
          <% if (currentUser.role === 'admin') { %>
            <a href="/admin/dashboard" class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-emerald-700">Admin</a>
          <% } %>
          <% if (currentUser.role === 'admin' || currentUser.role === 'petugas') { %>
            <a href="/admin/reports" class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-emerald-700">Semua Laporan</a>
          <% } %>
          <a href="/reports/map" class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-emerald-700">Peta Laporan</a>
          <a href="/reports/my" class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-emerald-700">Laporan Saya</a>
          <a href="/notifications" class="relative inline-flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 text-slate-700 transition hover:-translate-y-0.5 hover:bg-slate-100" aria-label="Notifikasi">
            <span aria-hidden="true">🔔</span>
            <span id="notificationBadge" data-count="<%= unreadNotificationCount || 0 %>" class="<%= unreadNotificationCount > 0 ? '' : 'hidden' %> absolute -right-1 -top-1 min-w-5 rounded-full bg-red-600 px-1.5 py-0.5 text-center text-[11px] font-bold leading-none text-white transition-transform">
              <%= unreadNotificationCount > 99 ? '99+' : unreadNotificationCount %>
            </span>
          </a>
          <% if (currentUser.role === 'warga') { %>
            <a href="/reports/new" class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-emerald-700 hover:shadow-md">Buat Laporan</a>
          <% } %>
          <span class="hidden max-w-[180px] truncate text-sm text-slate-600 xl:inline">Halo, <span class="font-medium text-slate-900"><%= currentUser.full_name || currentUser.email %></span></span>
          <form action="/logout" method="POST">
            <button type="submit" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-red-300 hover:bg-red-50 hover:text-red-700">Logout</button>
          </form>
        <% } else { %>
          <a href="/login" class="rounded-lg px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-emerald-700">Login</a>
          <a href="/register" class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-emerald-700 hover:shadow-md">Register</a>
        <% } %>
      </div>
    </div>

    <div id="mobileNavPanel" class="hidden border-t border-slate-100 pt-3 lg:hidden">
      <div class="grid gap-2">
        <% if (currentUser) { %>
          <% if (currentUser.role === 'admin') { %><a href="/admin/dashboard" class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100">Admin</a><% } %>
          <% if (currentUser.role === 'admin' || currentUser.role === 'petugas') { %><a href="/admin/reports" class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100">Semua Laporan</a><% } %>
          <a href="/reports/map" class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100">Peta Laporan</a>
          <a href="/reports/my" class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100">Laporan Saya</a>
          <a href="/notifications" class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100">🔔 Notifikasi <%= unreadNotificationCount > 0 ? `(${unreadNotificationCount > 99 ? '99+' : unreadNotificationCount})` : '' %></a>
          <% if (currentUser.role === 'warga') { %><a href="/reports/new" class="rounded-lg bg-emerald-600 px-3 py-2 text-sm font-semibold text-white transition hover:bg-emerald-700">Buat Laporan</a><% } %>
          <form action="/logout" method="POST"><button type="submit" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-left text-sm font-medium text-slate-700 transition hover:bg-red-50 hover:text-red-700">Logout</button></form>
        <% } else { %>
          <a href="/login" class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100">Login</a>
          <a href="/register" class="rounded-lg bg-emerald-600 px-3 py-2 text-sm font-semibold text-white transition hover:bg-emerald-700">Register</a>
        <% } %>
      </div>
    </div>
  </div>
</nav>

<% if (messages && messages.success && messages.success.length) { %>
  <div class="mx-auto mt-4 max-w-6xl px-4">
    <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 shadow-sm"><%= messages.success[0] %></div>
  </div>
<% } %>

<% if (messages && messages.error && messages.error.length) { %>
  <div class="mx-auto mt-4 max-w-6xl px-4">
    <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 shadow-sm"><%= messages.error[0] %></div>
  </div>
<% } %>

<script>
  (() => {
    const button = document.getElementById('mobileMenuButton');
    const panel = document.getElementById('mobileNavPanel');
    if (!button || !panel) return;

    button.addEventListener('click', () => {
      const isOpen = !panel.classList.contains('hidden');
      panel.classList.toggle('hidden', isOpen);
      button.setAttribute('aria-expanded', String(!isOpen));
      button.querySelector('span').textContent = isOpen ? '☰' : '×';
    });
  })();
</script>

<% if (currentUser && supabasePublicConfig && supabasePublicConfig.url && supabasePublicConfig.anonKey) { %>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script>
    (() => {
      const badge = document.getElementById('notificationBadge');
      const userId = '<%= currentUser.id %>';
      const supabaseUrl = '<%= supabasePublicConfig.url %>';
      const supabaseAnonKey = '<%= supabasePublicConfig.anonKey %>';

      if (!badge || !window.supabase || !userId || !supabaseUrl || !supabaseAnonKey) return;

      const client = window.supabase.createClient(supabaseUrl, supabaseAnonKey);

      function setBadgeCount(count) {
        const safeCount = Math.max(0, Number(count) || 0);
        badge.dataset.count = String(safeCount);
        badge.textContent = safeCount > 99 ? '99+' : String(safeCount);
        badge.classList.toggle('hidden', safeCount === 0);
        badge.classList.add('scale-110');
        window.setTimeout(() => badge.classList.remove('scale-110'), 180);
      }

      function incrementBadge() { setBadgeCount(Number(badge.dataset.count || 0) + 1); }
      function decrementBadge() { setBadgeCount(Number(badge.dataset.count || 0) - 1); }

      client.channel(`notifications:${userId}`)
        .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'notifications', filter: `user_id=eq.${userId}` }, (payload) => { if (!payload.new.is_read) incrementBadge(); })
        .on('postgres_changes', { event: 'UPDATE', schema: 'public', table: 'notifications', filter: `user_id=eq.${userId}` }, (payload) => {
          if (!payload.old.is_read && payload.new.is_read) decrementBadge();
          if (payload.old.is_read && !payload.new.is_read) incrementBadge();
        })
        .subscribe();
    })();
  </script>
<% } %>
