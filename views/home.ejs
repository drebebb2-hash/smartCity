<%- include('partials/header', { title }) %>

<main class="mx-auto max-w-6xl px-4 py-12 sm:py-16">
  <section class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-soft">
    <div class="grid gap-8 p-8 sm:p-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
      <div class="space-y-5">
        <p class="text-sm font-semibold uppercase tracking-wide text-emerald-700">Sistem Pelaporan Masalah Kota</p>
        <h1 class="text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">Smart City Report</h1>
        <p class="max-w-2xl text-lg leading-8 text-slate-600">Laporkan masalah kota, pantau status tindak lanjut, dan bantu petugas memperbaiki lingkungan sekitar dengan proses yang transparan.</p>
        <div class="flex flex-col gap-3 sm:flex-row">
          <% if (currentUser && currentUser.role === 'warga') { %>
            <a href="/reports/new" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-emerald-700 hover:shadow-md">Buat Laporan</a>
            <a href="/reports/map" class="inline-flex items-center justify-center rounded-lg border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-100">Lihat Peta</a>
          <% } else if (currentUser) { %>
            <a href="/reports/map" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-emerald-700 hover:shadow-md">Lihat Peta</a>
            <a href="/reports/my" class="inline-flex items-center justify-center rounded-lg border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-100">Laporan Saya</a>
          <% } else { %>
            <a href="/register" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-emerald-700 hover:shadow-md">Mulai Sekarang</a>
            <a href="/login" class="inline-flex items-center justify-center rounded-lg border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-100">Login</a>
          <% } %>
        </div>
      </div>
      <div class="rounded-3xl bg-gradient-to-br from-emerald-50 to-sky-50 p-6">
        <div class="grid gap-4">
          <% [['📍','Laporkan lokasi masalah'], ['🔔','Terima notifikasi status'], ['📊','Pantau statistik kota']].forEach((item) => { %>
            <div class="rounded-2xl border border-white/70 bg-white/80 p-4 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
              <div class="mb-3 flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-600 text-xl text-white"><%= item[0] %></div>
              <p class="font-semibold text-slate-900"><%= item[1] %></p>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
