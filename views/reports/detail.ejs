<%- include('../partials/header', { title }) %>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">

<main class="mx-auto max-w-6xl px-4 py-10">
  <% const statusMeta = getStatusMeta(report.status); %>

  <div class="mb-6">
    <a href="/reports/my" class="text-sm font-medium text-emerald-700 hover:text-emerald-800">Kembali ke Laporan Saya</a>
  </div>

  <section class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr]">
    <div class="space-y-6">
      <article class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
        <div class="bg-slate-100">
          <% if (report.photo_url) { %>
            <img src="<%= report.photo_url %>" alt="<%= report.title %>" class="max-h-[520px] w-full object-cover">
          <% } else { %>
            <div class="flex h-80 items-center justify-center text-slate-400">Tidak ada foto</div>
          <% } %>
        </div>
        <div class="space-y-5 p-6">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="text-sm text-slate-500">
                <%= report.categories?.icon ? `${report.categories.icon} ` : '' %><%= report.categories?.name || 'Tanpa kategori' %>
              </p>
              <h1 class="mt-2 text-3xl font-bold text-slate-950"><%= report.title %></h1>
            </div>
            <div class="flex flex-wrap items-center gap-2">
              <form action="/reports/<%= report.id %>/upvote" method="POST">
                <button type="submit" class="inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-sm font-semibold transition <%= hasUpvoted ? 'border-rose-200 bg-rose-600 text-white hover:bg-rose-700' : 'border-slate-300 bg-white text-slate-700 hover:border-rose-200 hover:bg-rose-50 hover:text-rose-700' %>">
                  <span aria-hidden="true"><%= hasUpvoted ? '♥' : '♡' %></span>
                  <span><%= upvoteCount %></span>
                </button>
              </form>
              <span class="w-fit rounded-full border px-3 py-1.5 text-sm font-semibold <%= statusMeta.className %>"><%= statusMeta.label %></span>
            </div>
          </div>

          <div>
            <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">Deskripsi</h2>
            <p class="mt-2 whitespace-pre-line leading-7 text-slate-700"><%= report.description %></p>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Dibuat</p>
              <p class="mt-1 text-sm font-medium text-slate-900"><%= formatDate(report.created_at) %></p>
            </div>
            <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Alamat</p>
              <p class="mt-1 text-sm font-medium text-slate-900"><%= report.address || 'Tidak ada keterangan alamat' %></p>
            </div>
          </div>
        </div>
      </article>

      <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-950">Lokasi</h2>
        <p class="mt-1 text-sm text-slate-500"><%= report.latitude %>, <%= report.longitude %></p>
        <div id="detailMap" class="mt-4 h-80 overflow-hidden rounded-lg border border-slate-300"></div>
      </section>

      <% if (currentUser && currentUser.role === 'admin') { %>
        <section class="rounded-lg border border-blue-200 bg-blue-50 p-6 shadow-sm">
          <div class="mb-5">
            <p class="text-sm font-semibold uppercase tracking-wide text-blue-700">Assignment</p>
            <h2 class="mt-1 text-lg font-semibold text-slate-950">Assign Petugas</h2>
            <p class="mt-1 text-sm text-slate-600">
              Petugas saat ini:
              <span class="font-semibold text-slate-900"><%= assignedPetugas ? assignedPetugas.full_name : 'Belum ditugaskan' %></span>
            </p>
          </div>

          <form action="/admin/reports/<%= report.id %>/assign" method="POST" class="space-y-4">
            <div>
              <label for="petugas_id" class="mb-2 block text-sm font-medium text-slate-700">Pilih Petugas</label>
              <select id="petugas_id" name="petugas_id" required class="w-full rounded-lg border border-blue-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-100">
                <option value="">Pilih petugas</option>
                <% petugasList.forEach((petugas) => { %>
                  <option value="<%= petugas.id %>" <%= report.assigned_to === petugas.id ? 'selected' : '' %>><%= petugas.full_name || petugas.id %></option>
                <% }) %>
              </select>
            </div>

            <div class="flex justify-end">
              <button type="submit" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-blue-700">
                Assign Petugas
              </button>
            </div>
          </form>
        </section>
      <% } %>

      <% if (currentUser && (currentUser.role === 'admin' || currentUser.role === 'petugas')) { %>
        <section class="rounded-lg border border-emerald-200 bg-emerald-50 p-6 shadow-sm">
          <div class="mb-5">
            <p class="text-sm font-semibold uppercase tracking-wide text-emerald-700">Panel Petugas</p>
            <h2 class="mt-1 text-lg font-semibold text-slate-950">Update Status Laporan</h2>
            <p class="mt-1 text-sm text-slate-600">Perubahan status akan tersimpan ke riwayat dan mengirim notifikasi ke warga pelapor.</p>
          </div>

          <form action="/admin/reports/<%= report.id %>/status" method="POST" class="space-y-4">
            <div>
              <label for="status" class="mb-2 block text-sm font-medium text-slate-700">Status Baru</label>
              <select id="status" name="status" required class="w-full rounded-lg border border-emerald-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100">
                <option value="pending" <%= report.status === 'pending' ? 'selected' : '' %>>Pending</option>
                <option value="diproses" <%= report.status === 'diproses' ? 'selected' : '' %>>Diproses</option>
                <option value="selesai" <%= report.status === 'selesai' ? 'selected' : '' %>>Selesai</option>
                <option value="ditolak" <%= report.status === 'ditolak' ? 'selected' : '' %>>Ditolak</option>
              </select>
            </div>

            <div>
              <label for="note" class="mb-2 block text-sm font-medium text-slate-700">Catatan Progres</label>
              <textarea id="note" name="note" rows="4" placeholder="Contoh: Petugas sudah menuju lokasi dan melakukan pengecekan." class="w-full resize-y rounded-lg border border-emerald-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100"></textarea>
            </div>

            <div class="flex justify-end">
              <button type="submit" class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-emerald-700">
                Update Status
              </button>
            </div>
          </form>
        </section>
      <% } %>

      <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
        <div class="mb-5 flex items-center justify-between gap-3">
          <div>
            <h2 class="text-lg font-semibold text-slate-950">Komentar</h2>
            <p class="mt-1 text-sm text-slate-500">Diskusi dan informasi tambahan terkait laporan ini.</p>
          </div>
          <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600"><%= comments.length %> komentar</span>
        </div>

        <form action="/reports/<%= report.id %>/comments" method="POST" class="mb-6 space-y-3">
          <label for="content" class="block text-sm font-medium text-slate-700">Tambah Komentar</label>
          <textarea id="content" name="content" rows="4" required placeholder="Tulis komentar atau informasi tambahan..." class="w-full resize-y rounded-lg border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100"></textarea>
          <div class="flex justify-end">
            <button type="submit" class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-emerald-700">
              Kirim Komentar
            </button>
          </div>
        </form>

        <% if (!comments.length) { %>
          <div class="rounded-lg border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-center text-sm text-slate-500">
            Belum ada komentar.
          </div>
        <% } else { %>
          <div class="space-y-4">
            <% comments.forEach((comment) => { %>
              <article class="rounded-lg border border-slate-200 bg-slate-50 p-4">
                <div class="mb-2 flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                  <p class="font-semibold text-slate-950"><%= comment.profiles?.full_name || 'Pengguna' %></p>
                  <time class="text-xs text-slate-500"><%= formatDate(comment.created_at) %></time>
                </div>
                <p class="whitespace-pre-line text-sm leading-6 text-slate-700"><%= comment.content %></p>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>
    </div>

    <aside class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-950">Riwayat Status</h2>

      <% if (!history.length) { %>
        <div class="mt-5 rounded-lg border border-slate-200 bg-slate-50 px-4 py-6 text-sm text-slate-500">
          Belum ada riwayat perubahan status.
        </div>
      <% } else { %>
        <ol class="mt-6 space-y-6">
          <% history.forEach((item) => { %>
            <% const itemStatus = item.status || item.new_status || item.status_to || report.status; %>
            <% const itemNote = item.note || item.notes || item.description || item.comment || 'Tidak ada catatan.'; %>
            <% const itemStatusMeta = getStatusMeta(itemStatus); %>
            <li class="relative border-l border-slate-200 pl-5">
              <span class="absolute -left-2 top-0 h-4 w-4 rounded-full border-2 border-white bg-emerald-600 shadow"></span>
              <div class="space-y-2">
                <span class="inline-flex rounded-full border px-2.5 py-1 text-xs font-semibold <%= itemStatusMeta.className %>"><%= itemStatusMeta.label %></span>
                <p class="text-sm font-medium text-slate-900"><%= formatDate(item.created_at) %></p>
                <p class="text-sm leading-6 text-slate-600"><%= itemNote %></p>
              </div>
            </li>
          <% }) %>
        </ol>
      <% } %>
    </aside>
  </section>
</main>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  const reportLat = Number('<%= report.latitude %>');
  const reportLng = Number('<%= report.longitude %>');
  const map = L.map('detailMap').setView([reportLat, reportLng], 15);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution: '&copy; OpenStreetMap'
  }).addTo(map);

  L.marker([reportLat, reportLng]).addTo(map);
</script>

<%- include('../partials/footer') %>
