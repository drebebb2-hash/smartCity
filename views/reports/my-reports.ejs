<%- include('../partials/header', { title }) %>

<main class="animate-fadeIn mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
  <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-indigo-600 dark:text-indigo-400">Laporan Warga</p>
      <h1 class="mt-2 text-3xl font-bold text-slate-950 dark:text-white">Laporan Saya</h1>
      <p class="mt-2 text-slate-600 dark:text-slate-400">Pantau laporan yang sudah Anda kirim dan status tindak lanjutnya.</p>
    </div>
    <% if (currentUser && currentUser.role === 'warga') { %>
      <a href="/reports/new" class="inline-flex rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-indigo-700">
        Buat Laporan
      </a>
    <% } %>
  </div>

  <% if (error) { %>
    <div class="mb-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
      <%= error %>
    </div>
  <% } %>

  <% if (!reports.length) { %>
    <section class="rounded-2xl border border-dashed border-slate-300 bg-white px-6 py-14 text-center shadow-sm dark:border-gray-700 dark:bg-gray-900">
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-emerald-50 text-indigo-600 dark:bg-emerald-950/30"><svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M7 3h7l4 4v14H7V3Z"/><path d="M14 3v5h5M9 13h6M9 17h4" stroke-linecap="round"/></svg></div>
      <h2 class="text-lg font-semibold text-slate-950 dark:text-white">Belum ada laporan</h2>
      <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Laporan yang Anda buat akan muncul di halaman ini.</p>
    </section>
  <% } else { %>
    <section class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <% reports.forEach((report) => { %>
        <% const statusMeta = getStatusMeta(report.status); %>
        <a href="/reports/<%= report.id %>" class="group relative overflow-hidden rounded-2xl bg-white shadow-md transition-all duration-200 hover:-translate-y-1 hover:shadow-xl dark:bg-gray-900">
          <div class="relative aspect-video bg-slate-200">
            <% if (report.photo_url) { %>
              <img src="<%= report.photo_url %>" alt="<%= report.title %>" class="h-full w-full object-cover transition duration-300 group-hover:scale-105">
            <% } else { %>
              <div class="flex h-full items-center justify-center bg-gradient-to-br from-indigo-100 to-blue-100 text-sm font-semibold text-indigo-500">Tidak ada foto</div>
            <% } %>
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950/50 via-transparent to-transparent"></div>
          </div>
            <div class="space-y-3 p-5">
            <div class="flex items-center justify-between gap-3">
              <span class="text-sm text-slate-500 dark:text-slate-400">
                <%= report.categories?.icon ? `${report.categories.icon} ` : '' %><%= report.categories?.name || 'Tanpa kategori' %>
              </span>
              <span class="absolute right-4 top-4 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wide <%= statusMeta.className %>"><%= statusMeta.label %></span>
            </div>
            <h2 class="line-clamp-2 text-lg font-semibold text-slate-950 group-hover:text-indigo-600 dark:text-white dark:group-hover:text-indigo-400"><%= report.title %></h2>
            <p class="text-sm text-slate-500 dark:text-slate-400"><%= formatDate(report.created_at) %></p>
            <% if (report.status === 'selesai') { %>
              <% if (report.userRating) { %>
                <span class="inline-flex items-center rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700 dark:bg-amber-950/30 dark:text-amber-400">
                  <span class="mr-1 text-amber-500">★</span> Sudah diberi rating <%= report.userRating.score %>/5
                </span>
              <% } else { %>
                <span class="inline-flex items-center rounded-lg bg-amber-500 px-3 py-2 text-xs font-semibold text-white transition group-hover:bg-amber-600">
                  <span class="mr-1">★</span> Beri Rating Sekarang
                </span>
              <% } %>
            <% } else { %>
              <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-500 dark:bg-gray-800 dark:text-slate-400">
                Rating tersedia setelah laporan selesai
              </span>
            <% } %>
          </div>
        </a>
      <% }) %>
    </section>
  <% } %>
</main>

<%- include('../partials/footer') %>
